{
  "theme": "maple",
  "name": "Vimapay Starter",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#333"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Документация",
        "groups": [
          {
            "group": "Документация",
            "pages": [
              "index",
              "requirements"
            ]
          },
          {
            "group": "Фиатные платежи",
            "pages": [
              "products/card",
              "products/openbanking",
              "products/googlepay",
              "products/applepay",
              "products/widget"
            ]
          },
          {
            "group": "Криптогейт",
            "pages": [
              "products/cryptogate/deposit",
              "products/cryptogate/pay-out"
            ]
          }
        ]
      },
      {
        "tab": "Finmar API",
        "groups": [
          {
            "group": "Фиатные платежи",
            "pages": [
              "/api-reference/introduction",
              "/api-reference/status",
              "/api-reference/integration/checkout",
              "/api-reference/integration/redirect_to_url",
              "/api-reference/integration/callbacks",
              "/api-reference/integration/client_confirm_payment",
              "/api-reference/go-live-checklist"
            ]
          },
          {
            "group": "Криптогейт",
            "pages": [
              "/api-reference/introduction",
              "/api-reference/status",
              "/api-reference/integration/cryptogate/networks",
              "/api-reference/integration/cryptogate/get-address",
              "/api-reference/integration/cryptogate/get-url",
              "/api-reference/integration/cryptogate/callbacks",
              "/api-reference/integration/cryptogate/confirm",
              "/api-reference/integration/cryptogate/checklist"
            ]
          },
          {
            "group": "API-методы",
            "openapi": "api-reference/openapi.json"
          }
        ]
      },
      {
        "tab": "Withdrawal Generic API",
        "groups": [
          {
            "group": "Withdrawal Generic API",
            "pages": [
              "/api-reference/withdrawal/integration",
              "/api-reference/withdrawal/authentication",
              "/api-reference/withdrawal/failure-codes",
              "/api-reference/withdrawal/notifications",
              "/api-reference/withdrawal/check-health",
              "/api-reference/withdrawal/get-balance",
              "/api-reference/withdrawal/create-operation",
              "/api-reference/withdrawal/create-operation-explicit-source",
              "/api-reference/withdrawal/get-operation-state",
              "/api-reference/withdrawal/start-operation",
              "/api-reference/withdrawal/abort-operation",
              "/api-reference/withdrawal/confirm-operation",
              "/api-reference/withdrawal/open-user-input"
            ],
            "openapi": "/api-reference/withdrawal/withdraw_generic_v2.json"
          }
        ]
      }
    ],
    "global": {}
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "curl",
        "javascript",
        "python",
        "php"
      ],
      "defaults": "all",
      "prefill": true
    }
  },
  "logo": {
    "light": "/logo/logo.vimapay.svg",
    "dark": "/logo/logo.vimapay.dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@vimapay.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Integration Manager",
      "href": "https://t.me/integrationVimapay"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/vimapay",
      "github": "https://github.com/vimapay",
      "linkedin": "https://linkedin.com/company/vimapay"
    }
  }
}